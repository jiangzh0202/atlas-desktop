{
  "meta": {
    "name": "Atlas 定价审视表",
    "version": "1.0",
    "description": "AI 数字员工训练时系统扫描的完整维度。客户上传历史报价后，AI 按此框架逐项提取规则，形成后端记忆。",
    "last_updated": "2026-06-19"
  },
  "inspection_framework": {
    "step_1_客户输入识别": {
      "desc": "客户发来的询盘中包含哪些字段，AI 需要识别并补全",
      "columns": [
        "OE号/零件号",
        "品名(中文/俄文/英文)",
        "数量",
        "单位",
        "目的地国家"
      ],
      "AI_actions": [
        "解析俄文/英文品名 → 匹配到中文品名",
        "OE号 → 匹配到供货号(supplier_part_number)",
        "OE号 → 确定品牌(卡友配/A2080/E9300/BOSCH/副厂/东亚等)",
        "数量 → 确定数量区段(1-10件/10-30件/30-100件/100+件)",
        "目的地 → 确定地区(东亚/中东/东欧/非洲/南美/中亚)"
      ]
    },
    "step_2_产品成本计算": {
      "desc": "每件配件的成本构成",
      "factors": {
        "进价基准": {
          "含税进价": "从恩同ERP/供应商表获取含税进价",
          "不含税进价": "进价÷1.13(13%增值税)",
          "数据源": [
            "恩同ERP(福田/东风康明斯/康明斯中国/东风商用车)",
            "本地Excel(舍弗勒/副厂件)"
          ],
          "动态性": "恩同ERP = 动态; 本地Excel = 静态"
        },
        "费用加项": {
          "人工费": "按品类固定加价",
          "FOB费用": "到港费用(FOB方式)",
          "CNF费用": "到港+运费",
          "CIF费用": "到港+运费+保险",
          "公司运营管理费": "固定百分比或绝对值",
          "利润率": "由折扣后的最终利润率决定"
        }
      }
    },
    "step_3_折扣规则矩阵": {
      "desc": "这是最核心的定价逻辑——按品牌×品类×数量×库存状态决定折扣点数",
      "品牌折扣表": {
        "卡友配": {
          "适用范围": "福田康明斯ISF2.8/3.8配件",
          "规则": [
            {
              "条件": "单笔金额>10万",
              "折扣点数": 13,
              "折扣系数": 0.87
            },
            {
              "条件": "数量≥10件 且 单价>1000",
              "折扣点数": "25.5(顶格)",
              "折扣系数": 0.745
            },
            {
              "条件": "常规",
              "折扣点数": "13-18",
              "折扣系数": "0.82-0.87"
            },
            {
              "条件": "本月福田任务未完成",
              "规则": "折扣点数加2-3个点(更优惠)"
            }
          ]
        },
        "A2080_ISF散件": {
          "适用范围": "福田康明斯ISF系列散件全品种",
          "规则": [
            {
              "条件": "单价≤5元",
              "折扣点数": "无(原价)",
              "折扣系数": 1.0
            },
            {
              "条件": "5<单价≤50元",
              "折扣点数": "15-17",
              "折扣系数": "0.83-0.85"
            },
            {
              "条件": "50<单价≤1000元",
              "折扣点数": "数量<30时23; 数量≥30时24",
              "折扣系数": "0.76-0.77"
            },
            {
              "条件": "1000<单价≤10000元",
              "折扣点数": "数量<10时24; 数量≥10时25.5",
              "折扣系数": "0.745-0.76"
            },
            {
              "条件": "单价>10000元",
              "折扣点数": "25.5(顶格)",
              "折扣系数": 0.745
            }
          ]
        },
        "E9300_欧康": {
          "适用范围": "福田欧康2.5系列(福田G21发动机配套)",
          "规则": [
            {
              "条件": "单价>1000元 且 数量≥30",

  "training_protocol": {
    "desc": "客户上传历史报价Excel时，AI数字员工的训练流程",
    "steps": [
      "1. 自动识别Excel列名 → 映射到审视表维度",
      "2. 遍历每行数据 → 提取折扣规则(按品牌×品类×数量分组的折扣模式)",
      "3. 模式识别 → 发现'库存一口价'、'含税进价给客户'等特殊模式",
      "4. 异常检测 → 标出偏离常规折扣的行(可能是人工调整或特殊情况)",
      "5. 生成 training_report.json → 可人工审核后确认",
      "6. 确认后的规则 → 写入 pricing_rules.json → 成为后端记忆",
      "7. 后续报价 → AI自动查阅 pricing_rules.json + pricing_factors.json → 计算价格"
    ]
  }
}
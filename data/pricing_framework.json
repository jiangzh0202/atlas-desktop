            "条件": "无牌价",
            "定价方式": "B+进价 或 含税进价直接给客户"
          }
        },
        "BOSCH": {
          "适用范围": "燃油泵等精密件",
          "规则": {
            "条件": "全新中性包装",
            "折扣点数": 24,
            "折扣系数": 0.76
          }
        },
        "东亚": {
          "适用范围": "后处理装置等",
          "规则": {
            "条件": "国6后处理件",
            "折扣点数": 4,
            "折扣系数": 0.96
